# API Keys Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control

# Google Places API Key (for place search/details)
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Google Maps SDK Keys (for native map display)
GOOGLE_MAPS_ANDROID_API_KEY=your_google_maps_android_key
GOOGLE_MAPS_IOS_API_KEY=your_google_maps_ios_key

# Google OAuth Client IDs
GOOGLE_OAUTH_CLIENT_ID=your_android_oauth_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_ID_ANDROID=your_android_oauth_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_ID_IOS=your_ios_oauth_client_id.apps.googleusercontent.com

# OAuth Feature Flag
USE_REAL_OAUTH=true

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# Firebase API Keys
FIREBASE_ANDROID_API_KEY=your_firebase_android_api_key
FIREBASE_IOS_API_KEY=your_firebase_ios_api_key
FIREBASE_WEB_API_KEY=your_firebase_web_api_key

# Weather API
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key

# Hugging Face
HF_TOKEN=your_hugging_face_token
