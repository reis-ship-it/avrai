{
  "schema_version": "1.0.0",
  "global": {
    "required_common_fields": [
      "event_id",
      "agent_id",
      "entity_type",
      "entity_id",
      "action_type",
      "state_before",
      "next_state",
      "outcome",
      "timestamp_utc",
      "consent_scope",
      "feature_spec_version",
      "label_spec_version"
    ],
    "required_location_fields": [
      "geohash",
      "locality_code",
      "city_code",
      "timezone"
    ],
    "uniform_training_stages": [
      "offline_replay",
      "shadow",
      "limited_rollout"
    ],
    "uniform_writing_pattern": {
      "decision_log_template": "<model_id> <stage> <pass_or_fail> <metric>=<value> threshold=<threshold> action=<next_action>",
      "summary_style": "Short declarative lines, explicit units, no ambiguous language.",
      "required_sections": [
        "Scope",
        "Dataset",
        "Metrics",
        "Decision",
        "Follow-up"
      ]
    }
  },
