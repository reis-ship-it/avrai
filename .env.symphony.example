# Copy to `.env.symphony` and fill in real values.
# This file is safe to commit; `.env.symphony` is ignored by git via `.env.*`.

# Required
LINEAR_API_KEY=replace_with_linear_personal_api_key
SYMPHONY_LINEAR_PROJECT_SLUG=replace_with_linear_project_slug

# Optional
# SYMPHONY_ELIXIR_DIR=$HOME/code/symphony/elixir
# SYMPHONY_SOURCE_REPO_URL=/Users/reisgordon/AVRAI
# SYMPHONY_GIT_PUSH_REMOTE_URL=https://github.com/reis-ship-it/avrai.git
# SYMPHONY_LOCAL_REPO_SNAPSHOT=/Users/reisgordon/AVRAI
# SYMPHONY_WORKSPACE_ROOT=/Users/reisgordon/AVRAI/.symphony-workspaces
# SYMPHONY_LOGS_ROOT=/Users/reisgordon/AVRAI/.symphony-logs
# SYMPHONY_PORT=4020
# MISE_BIN=/opt/homebrew/bin/mise
# CODEX_BIN=/absolute/path/to/codex
# SYMPHONY_CODEX_COMMAND="$CODEX_BIN app-server"
# SYMPHONY_BASE_REF=bham-beta
# AVRAI_SYMPHONY_BOOTSTRAP_MODE=light
# SYMPHONY_WORK_BRANCH_PREFIX=agent/symphony

# Safety notes:
# - `start_local_symphony.sh` refuses to start if the local source repo is dirty.
# - It also refuses to start if the local source repo is behind the configured base ref.
