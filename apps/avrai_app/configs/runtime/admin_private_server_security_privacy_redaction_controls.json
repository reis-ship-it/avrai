{
  "control_pack_id": "admin_private_server_security_privacy_redaction",
  "scope": "phase-e privacy-safe response and redaction controls for admin surfaces",
  "master_plan_refs": ["10.9.22", "10.9.24", "10.9.25"],
  "related_milestones": ["M26-P10-3"],
  "response_contracts": {
    "agent_identity_only_rendering": true,
    "direct_user_pii_fields_allowed": false,
    "forbidden_fields": [
      "name",
      "email",
      "phone",
      "home_address",
      "personal_address",
      "ssn",
      "government_id"
    ]
  },
  "redaction_pipeline": {
    "server_side_redaction_middleware_required": true,
    "schema_level_pii_blocking_required": true,
    "tokenization_for_traceability_allowed": true,
    "fail_closed_on_redaction_failure": true
  },
  "quality_gates": {
    "privacy_contract_tests_required": true,
    "pii_leakage_gate_blocks_release": true,
    "privacy_breach_alerting_required": true
  },
  "status": "starter",
  "last_updated": "2026-02-28",
  "notes": "Aligns with command-center policy of agent identity + aggregate telemetry only."
}
